cs":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[],"output":{"Deduplicated":0}},"src":"TopLevel","is_global_initializer":0,"body":{"Structured":{"span":{"data":{"file_id":0,"beg":{"line":0,"col":0},"end":{"line":0,"col":0}},"generated_from_span":null},"bound_body_regions":0,"locals":{"arg_count":0,"locals":[{"index":0,"name":null,"span":{"data":{"file_id":0,"beg":{"line":0,"col":0},"end":{"line":0,"col":0}},"generated_from_span":null},"ty":{"Deduplicated":0}}]},"body":{"span":{"data":{"file_id":0,"beg":{"line":0,"col":0},"end":{"line":0,"col":0}},"generated_from_span":null},"statements":[{"span":{"data":{"file_id":0,"beg":{"line":0,"col":0},"end":{"line":0,"col":0}},"generated_from_span":null},"id":164,"kind":{"Assign":[{"kind":{"Local":0},"ty":{"Deduplicated":0}},{"Aggregate":[{"Adt":[{"id":"Tuple","generics":{"regions":[],"types":[],"const_generics":[],"trait_refs":[]}},null,null]},[]]}]},"comments_before":[]},{"span":{"data":{"file_id":0,"beg":{"line":0,"col":0},"end":{"line":0,"col":0}},"generated_from_span":null},"id":165,"kind":"Return","comments_before":[]}]},"comments":[]}}},{"def_id":27,"item_meta":{"name":[{"Ident":["coalesced_success_test",0]},{"Ident":["logic_and_patterns",0]},{"Ident":["edge_cases_modules_test_6_2_logic_visibility",0]},{"Ident":["inner",0]},{"Ident":["helper",0]}],"span":{"data":{"file_id":3,"beg":{"line":4,"col":8},"end":{"line":4,"col":44}},"generated_from_span":null},"source_text":"pub(crate) fn helper() -> u32 { 42 }","attr_info":{"attributes":[],"inline":null,"rename":null,"public":false},"is_local":true,"opacity":"Transparent","lang_item":null},"generics":{"regions":[],"types":[],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[],"output":{"Deduplicated":1}},"src":"TopLevel","is_global_initializer":null,"body":{"Structured":{"span":{"data":{"file_id":3,"beg":{"line":4,"col":8},"end":{"line":4,"col":44}},"generated_from_span":null},"bound_body_regions":0,"locals":{"arg_count":0,"locals":[{"index":0,"name":null,"span":{"data":{"file_id":3,"beg":{"line":4,"col":34},"end":{"line":4,"col":37}},"generated_from_span":null},"ty":{"Deduplicated":1}}]},"body":{"span":{"data":{"file_id":3,"beg":{"line":4,"col":40},"end":{"line":4,"col":44}},"generated_from_span":null},"statements":[{"span":{"data":{"file_id":3,"beg":{"line":4,"col":40},"end":{"line":4,"col":42}},"generated_from_span":null},"id":166,"kind":{"Assign":[{"kind":{"Local":0},"ty":{"Deduplicated":1}},{"Use":{"Const":{"kind":{"Literal":{"Scalar":{"Unsigned":["U32","42"]}}},"ty":{"Deduplicated":1}}}}]},"comments_before":[]},{"span":{"data":{"file_id":3,"beg":{"line":4,"col":44},"end":{"line":4,"col":44}},"generated_from_span":null},"id":167,"kind":"Return","comments_before":[]}]},"comments":[]}}},{"def_id":28,"item_meta":{"name":[{"Ident":["core",0]},{"Ident":["mem",0]},{"Ident":["size_of",0]}],"span":{"data":{"file_id":7,"beg":{"line":344,"col":0},"end":{"line":344,"col":34}},"generated_from_span":null},"source_text":null,"attr_info":{"attributes":[{"DocComment":" Returns the size of a type in bytes."},{"DocComment":""},{"DocComment":" More specifically, this is the offset in bytes between successive elements"},{"DocComment":" in an array with that item type including alignment padding. Thus, for any"},{"DocComment":" type `T` and length `n`, `[T; n]` has a size of `n * size_of::<T>()`."},{"DocComment":""},{"DocComment":" In general, the size of a type is not stable across compilations, but"},{"DocComment":" specific types such as primitives are."},{"DocComment":""},{"DocComment":" The following table gives the size for primitives."},{"DocComment":""},{"DocComment":" Type | `size_of::<Type>()`"},{"DocComment":" ---- | ---------------"},{"DocComment":" () | 0"},{"DocComment":" bool | 1"},{"DocComment":" u8 | 1"},{"DocComment":" u16 | 2"},{"DocComment":" u32 | 4"},{"DocComment":" u64 | 8"},{"DocComment":" u128 | 16"},{"DocComment":" i8 | 1"},{"DocComment":" i16 | 2"},{"DocComment":" i32 | 4"},{"DocComment":" i64 | 8"},{"DocComment":" i128 | 16"},{"DocComment":" f32 | 4"},{"DocComment":" f64 | 8"},{"DocComment":" char | 4"},{"DocComment":""},{"DocComment":" Furthermore, `usize` and `isize` have the same size."},{"DocComment":""},{"DocComment":" The types [`*const T`], `&T`, [`Box<T>`], [`Option<&T>`], and `Option<Box<T>>` all have"},{"DocComment":" the same size. If `T` is `Sized`, all of those types have the same size as `usize`."},{"DocComment":""},{"DocComment":" The mutability of a pointer does not change its size. As such, `&T` and `&mut T`"},{"DocComment":" have the same size. Likewise for `*const T` and `*mut T`."},{"DocComment":""},{"DocComment":" # Size of `#[repr(C)]` items"},{"DocComment":""},{"DocComment":" The `C` representation for items has a defined layout. With this layout,"},{"DocComment":" the size of items is also stable as long as all fields have a stable size."},{"DocComment":""},{"DocComment":" ## Size of Structs"},{"DocComment":""},{"DocComment":" For `struct`s, the size is determined by the following algorithm."},{"DocComment":""},{"DocComment":" For each field in the struct ordered by declaration order:"},{"DocComment":""},{"DocComment":" 1. Add the size of the field."},{"DocComment":" 2. Round up the current size to the nearest multiple of the next field's [alignment]."},{"DocComment":""},{"DocComment":" Finally, round the size of the struct to the nearest multiple of its [alignment]."},{"DocComment":" The alignment of the struct is usually the largest alignment of all its"},{"DocComment":" fields; this can be changed with the use of `repr(align(N))`."},{"DocComment":""},{"DocComment":" Unlike `C`, zero sized structs are not rounded up to one byte in size."},{"DocComment":""},{"DocComment":" ## Size of Enums"},{"DocComment":""},{"DocComment":" Enums that carry no data other than the discriminant have the same size as C enums"},{"DocComment":" on the platform they are compiled for."},{"DocComment":""},{"DocComment":" ## Size of Unions"},{"DocComment":""},{"DocComment":" The size of a union is the size of its largest field."},{"DocComment":""},{"DocComment":" Unlike `C`, zero sized unions are not rounded up to one byte in size."},{"DocComment":""},{"DocComment":" # Examples"},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" // Some primitives"},{"DocComment":" assert_eq!(4, size_of::<i32>());"},{"DocComment":" assert_eq!(8, size_of::<f64>());"},{"DocComment":" assert_eq!(0, size_of::<()>());"},{"DocComment":""},{"DocComment":" // Some arrays"},{"DocComment":" assert_eq!(8, size_of::<[i32; 2]>());"},{"DocComment":" assert_eq!(12, size_of::<[i32; 3]>());"},{"DocComment":" assert_eq!(0, size_of::<[i32; 0]>());"},{"DocComment":""},{"DocComment":""},{"DocComment":" // Pointer size equality"},{"DocComment":" assert_eq!(size_of::<&i32>(), size_of::<*const i32>());"},{"DocComment":" assert_eq!(size_of::<&i32>(), size_of::<Box<i32>>());"},{"DocComment":" assert_eq!(size_of::<&i32>(), size_of::<Option<&i32>>());"},{"DocComment":" assert_eq!(size_of::<Box<i32>>(), size_of::<Option<Box<i32>>>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" Using `#[repr(C)]`."},{"DocComment":""},{"DocComment":" ```"},{"DocComment":" #[repr(C)]"},{"DocComment":" struct FieldStruct {"},{"DocComment":"     first: u8,"},{"DocComment":"     second: u16,"},{"DocComment":"     third: u8"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" // The size of the first field is 1, so add 1 to the size. Size is 1."},{"DocComment":" // The alignment of the second field is 2, so add 1 to the size for padding. Size is 2."},{"DocComment":" // The size of the second field is 2, so add 2 to the size. Size is 4."},{"DocComment":" // The alignment of the third field is 1, so add 0 to the size for padding. Size is 4."},{"DocComment":" // The size of the third field is 1, so add 1 to the size. Size is 5."},{"DocComment":" // Finally, the alignment of the struct is 2 (because the largest alignment amongst its"},{"DocComment":" // fields is 2), so add 1 to the size for padding. Size is 6."},{"DocComment":" assert_eq!(6, size_of::<FieldStruct>());"},{"DocComment":""},{"DocComment":" #[repr(C)]"},{"DocComment":" struct TupleStruct(u8, u16, u8);"},{"DocComment":""},{"DocComment":" // Tuple structs follow the same rules."},{"DocComment":" assert_eq!(6, size_of::<TupleStruct>());"},{"DocComment":""},{"DocComment":" // Note that reordering the fields can lower the size. We can remove both padding bytes"},{"DocComment":" // by putting `third` before `second`."},{"DocComment":" #[repr(C)]"},{"DocComment":" struct FieldStructOptimized {"},{"DocComment":"     first: u8,"},{"DocComment":"     third: u8,"},{"DocComment":"     second: u16"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(4, size_of::<FieldStructOptimized>());"},{"DocComment":""},{"DocComment":" // Union size is the size of the largest field."},{"DocComment":" #[repr(C)]"},{"DocComment":" union ExampleUnion {"},{"DocComment":"     smaller: u8,"},{"DocComment":"     larger: u16"},{"DocComment":" }"},{"DocComment":""},{"DocComment":" assert_eq!(2, size_of::<ExampleUnion>());"},{"DocComment":" ```"},{"DocComment":""},{"DocComment":" [alignment]: align_of"},{"DocComment":" [`*const T`]: primitive@pointer"},{"DocComment":" [`Box<T>`]: ../../std/boxed/struct.Box.html"},{"DocComment":" [`Option<&T>`]: crate::option::Option"},{"DocComment":""},{"Unknown":{"path":"rustc_diagnostic_item","args":"\"mem_size_of\""}}],"inline":"Always","rename":null,"public":true},"is_local":false,"opacity":"Foreign","lang_item":"mem_size_of"},"generics":{"regions":[],"types":[{"index":0,"name":"T"}],"const_generics":[],"trait_clauses":[],"regions_outlive":[],"types_outlive":[],"trait_type_constraints":[]},"signature":{"is_unsafe":false,"inputs":[],"output":{"Deduplicated":4}},"src":"TopLevel","is_global_initia