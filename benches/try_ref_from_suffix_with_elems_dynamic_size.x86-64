	movabs rax, 4611686018427387901
	cmp rcx, rax
	ja .LBB5_3
	lea rax, [2*rcx + 4]
	mov r8, rsi
	sub r8, rax
	jae .LBB5_4
.LBB5_3:
	xor eax, eax
	ret
.LBB5_4:
	add esi, edi
	xor edx, edx
	mov eax, 0
	test sil, 1
	jne .LBB5_6
	lea rsi, [rdi + r8]
	movzx edi, word ptr [rdi + r8]
	cmp di, -16192
	mov edx, 2
	cmove rdx, rcx
	xor eax, eax
	cmp edi, 49344
	cmove rax, rsi
