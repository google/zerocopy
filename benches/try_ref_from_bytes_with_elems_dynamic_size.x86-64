bench_try_ref_from_bytes_with_elems_dynamic_size:
	movabs rax, 9223372036854775805
	cmp rdx, rax
	seta cl
	mov rax, rdi
	or dil, cl
	test dil, 1
	jne .LBB28_3
	lea rcx, [2*rdx + 4]
	cmp rsi, rcx
	jne .LBB28_3
	cmp word ptr [rax], -16192
	je .LBB28_4
.LBB28_3:
	xor eax, eax
	mov rdx, rsi
.LBB28_4:
	ret
