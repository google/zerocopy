bench_ref_from_prefix_with_elems_dynamic_padding:
	mov rcx, rdx
	mov edx, 1
	movabs rax, 3074457345618258598
	cmp rcx, rax
	ja .LBB5_3
	lea rax, [rcx + 2*rcx]
	or rax, 3
	add rax, 9
	cmp rax, rsi
	jbe .LBB5_4
.LBB5_3:
	xor eax, eax
	ret
.LBB5_4:
	xor eax, eax
	test dil, 3
	cmovne rcx, rax
	cmove rax, rdi
	mov rdx, rcx
	ret
