bench_try_ref_from_bytes_dynamic_size:
	cmp rsi, 4
	jb .LBB5_1
	test dil, 1
	jne .LBB5_1
	mov rdx, rsi
	lea rcx, [rsi - 4]
	mov rax, rcx
	and rax, -2
	add rax, 4
	cmp rsi, rax
	jne .LBB5_1
	shr rcx
	movzx esi, word ptr [rdi]
	xor eax, eax
	cmp esi, 49344
	cmove rdx, rcx
	cmove rax, rdi
	ret
.LBB5_1:
	xor eax, eax
	ret
