bench_try_ref_from_prefix_dynamic_size:
	andi a2, a0, 1
	bnez a2, .LBB30_3
	li a2, 4
	bgeu a1, a2, .LBB30_4
	li a0, 0
	li a1, 1
	ret
.LBB30_3:
	li a1, 0
	li a0, 0
	ret
.LBB30_4:
	lbu a2, 1(a0)
	lbu a3, 0(a0)
	lui a4, 12
	slli a2, a2, 8
	or a3, a3, a2
	addi a4, a4, 192
	xor a2, a3, a4
	snez a2, a2
	beq a3, a4, .LBB30_6
	li a1, 2
	addi a2, a2, -1
	and a0, a0, a2
	ret
.LBB30_6:
	addi a1, a1, -4
	srli a1, a1, 1
	addi a2, a2, -1
	and a0, a0, a2
	ret
