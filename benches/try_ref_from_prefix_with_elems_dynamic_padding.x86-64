bench_try_ref_from_prefix_with_elems_dynamic_padding:
	mov rcx, rdx
	mov edx, 1
	movabs rax, 3074457345618258598
	cmp rcx, rax
	ja .LBB5_4
	lea rax, [rcx + 2*rcx]
	or rax, 3
	add rax, 9
	cmp rax, rsi
	jbe .LBB5_2
.LBB5_4:
	xor eax, eax
.LBB5_5:
	ret
.LBB5_2:
	xor edx, edx
	mov eax, 0
	test dil, 3
	jne .LBB5_5
	movzx esi, word ptr [rdi]
	cmp si, -16192
	mov edx, 2
	cmove rdx, rcx
	xor eax, eax
	cmp esi, 49344
	cmove rax, rdi
	ret
