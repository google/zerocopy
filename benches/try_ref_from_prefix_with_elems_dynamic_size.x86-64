bench_try_ref_from_prefix_with_elems_dynamic_size:
	movabs rax, 9223372036854775805
	cmp rdx, rax
	ja .LBB33_1
	mov rcx, rdx
	xor edx, edx
	mov eax, 0
	test dil, 1
	jne .LBB33_5
	lea rax, [2*rcx + 4]
	cmp rax, rsi
	jbe .LBB33_4
.LBB33_1:
	xor eax, eax
	mov edx, 1
	ret
.LBB33_4:
	movzx esi, word ptr [rdi]
	cmp si, -16192
	mov edx, 2
	cmove rdx, rcx
	xor eax, eax
	cmp esi, 49344
	cmove rax, rdi
.LBB33_5:
	ret
