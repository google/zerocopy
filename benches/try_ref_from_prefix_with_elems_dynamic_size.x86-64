bench_try_ref_from_prefix_with_elems_dynamic_size:
	mov rcx, rdx
	mov edx, 1
	movabs rax, 4611686018427387901
	cmp rcx, rax
	ja .LBB5_3
	lea rax, [2*rcx + 4]
	cmp rax, rsi
	jbe .LBB5_4
.LBB5_3:
	xor eax, eax
	ret
.LBB5_4:
	xor edx, edx
	mov eax, 0
	test dil, 1
	jne .LBB5_6
	movzx esi, word ptr [rdi]
	cmp si, -16192
	mov edx, 2
	cmove rdx, rcx
	xor eax, eax
	cmp esi, 49344
	cmove rax, rdi
.LBB5_6:
