bench_ref_from_prefix_with_elems_dynamic_padding:
	mv a3, a1
	li a1, 3
	mulhu a4, a2, a1
	li a1, 1
	bnez a4, .LBB11_3
	slli a4, a2, 1
	add a4, a4, a2
	li a5, -10
	bltu a5, a4, .LBB11_3
	ori a5, a4, 3
	not a4, a4
	andi a4, a4, 3
	addi a5, a5, 9
	bgeu a5, a4, .LBB11_4
.LBB11_3:
	li a0, 0
