	mov r7, sp
	cmp r2, #6
	blo .LBB23_3
	add r2, r1
	ldr r12, [r2, #-6]
	movw r1, #49344
	uxth.w r3, r12
	cmp r3, r1
	bne .LBB23_3
	ldrh r1, [r2, #-2]
