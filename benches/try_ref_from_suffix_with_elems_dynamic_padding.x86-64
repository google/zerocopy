bench_try_ref_from_suffix_with_elems_dynamic_padding:
	mov rcx, rdx
	mov edx, 1
	movabs rax, 3074457345618258598
	cmp rcx, rax
	ja .LBB5_4
	lea rax, [rcx + 2*rcx]
	or rax, 3
	add rax, 9
	mov r8, rsi
	sub r8, rax
	jae .LBB5_2
.LBB5_4:
	xor eax, eax
.LBB5_5:
	ret
.LBB5_2:
	add esi, edi
	xor edx, edx
	mov eax, 0
	test sil, 3
	jne .LBB5_5
	lea rsi, [rdi + r8]
	movzx edi, word ptr [rdi + r8]
	cmp di, -16192
	mov edx, 2
	cmove rdx, rcx
	xor eax, eax
	cmp edi, 49344
	cmove rax, rsi
