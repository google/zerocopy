bench_try_ref_from_bytes_with_elems_dynamic_padding:
	movabs rcx, 3074457345618258598
	cmp rdx, rcx
	ja .LBB5_4
	mov rax, rdi
	test al, 3
	jne .LBB5_4
	lea rcx, [rdx + 2*rdx]
	or rcx, 3
	add rcx, 9
	cmp rsi, rcx
	jne .LBB5_4
	cmp word ptr [rax], -16192
	je .LBB5_5
.LBB5_4:
	xor eax, eax
	mov rdx, rsi
.LBB5_5:
	ret
