bench_ref_from_prefix_with_elems_dynamic_size:
	push {r7, lr}
	mov r7, sp
	movw r3, #65533
	movt r3, #32767
	cmp r2, r3
	bhi .LBB12_4
	lsls r3, r0, #31
	bne .LBB12_3
	adds r3, r2, #2
	lsls r3, r3, #1
	cmp r3, r1
	itt hi
	movhi r0, #0
	movhi r2, #1
	mov r1, r2
	pop {r7, pc}
.LBB12_3:
	movs r1, #0
	movs r0, #0
	pop {r7, pc}
.LBB12_4:
	movs r0, #0
	movs r1, #1
	pop {r7, pc}
